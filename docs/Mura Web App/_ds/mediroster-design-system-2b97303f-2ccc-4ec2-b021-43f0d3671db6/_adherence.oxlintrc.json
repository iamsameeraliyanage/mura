{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/calendar/**",
              "components/chips/**",
              "components/fairness/**",
              "components/feedback/**",
              "components/navigation/**",
              "ui_kits/mediroster/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalendarCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:day|pen|label|secondaryPen|secondaryLabel|flags|conflict|weekend|holiday|today|muted|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<CalendarCell> doesn't accept that prop. Declared props: day, pen, label, secondaryPen, secondaryLabel, flags, conflict, weekend, holiday, today, muted, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PenMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|ink|bg|dot|name|key|ref|className|style|children)$/]",
        "message": "<PenMeta> doesn't accept that prop. Declared props: label, ink, bg, dot, name."
      },
      {
        "selector": "JSXOpeningElement[name.name='FairnessTallies'] > JSXAttribute > JSXIdentifier[name!=/^(?:onCall|cash|postCash|weekend|key|ref|className|style|children)$/]",
        "message": "<FairnessTallies> doesn't accept that prop. Declared props: onCall, cash, postCash, weekend."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlagBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|withText|style|key|ref|className|style|children)$/]",
        "message": "<FlagBadge> doesn't accept that prop. Declared props: type, label, withText, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlagBadge'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:cash|postcash|conflict)$/]",
        "message": "<FlagBadge> type must be one of 'cash' | 'postcash' | 'conflict'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MonthGrid'] > JSXAttribute > JSXIdentifier[name!=/^(?:days|compact|onCellClick|style|key|ref|className|style|children)$/]",
        "message": "<MonthGrid> doesn't accept that prop. Declared props: days, compact, onCellClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|active|variant|badge|onClick|style|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: children, icon, active, variant, badge, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:sidebar|bottom)$/]",
        "message": "<NavItem> variant must be one of 'sidebar' | 'bottom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrimaryButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PrimaryButton> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrimaryButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|destructive|ghost)$/]",
        "message": "<PrimaryButton> variant must be one of 'solid' | 'outline' | 'destructive' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrimaryButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PrimaryButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrimaryButton'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<PrimaryButton> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|version|style|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, version, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:draft|published)$/]",
        "message": "<StatusBadge> status must be one of 'draft' | 'published'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ValidationAlert'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|title|description|onJump|jumpLabel|style|key|ref|className|style|children)$/]",
        "message": "<ValidationAlert> doesn't accept that prop. Declared props: severity, title, description, onJump, jumpLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ValidationAlert'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:warning|error)$/]",
        "message": "<ValidationAlert> severity must be one of 'warning' | 'error'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
