// 03 — Database Schema (Prisma)
// Hospital Roster App — encodes the verified logic in 01-roster-app-logic-summary.md
// Postgres on Neon. DATABASE_URL = pooled, DIRECT_URL = direct (migrations).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Org hierarchy ─────────────────────────
// Hospital → Department → Unit. Phase 1: one hospital, dept "Paediatrics",
// unit "Prof Unit". The unit level exists NOW so multi-unit expansion is UI-only.

model Hospital {
  id          String       @id @default(cuid())
  name        String
  city        String?
  departments Department[]
  createdAt   DateTime     @default(now())
}

model Department {
  id         String   @id @default(cuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  name       String // "Paediatrics"
  units      Unit[]
  createdAt  DateTime @default(now())

  @@unique([hospitalId, name])
}

model Unit {
  id           String        @id @default(cuid())
  departmentId String
  department   Department    @relation(fields: [departmentId], references: [id])
  name         String // "Prof Unit"
  staff        StaffMember[]
  rosters      Roster[]
  dutyConfigs  DutyConfig[]
  users        User[]
  rotationStates WeekendRotationState[]
  createdAt    DateTime      @default(now())

  @@unique([departmentId, name])
}

// ───────────────────────── People ─────────────────────────

enum StaffKind {
  CONSULTANT
  SHO
  RHO
  HO // future
  MO // future
  NURSE // future
}

model StaffMember {
  id        String    @id @default(cuid())
  unitId    String
  unit      Unit      @relation(fields: [unitId], references: [id])
  kind      StaffKind
  fullName  String // "Dr. Lal Rathnasiri"
  shortCode String // "R", "Pu", "S" — what's drawn on the calendar chip
  colorKey  String // design-system token key, e.g. "doctor-r" (mirrors pen colors)

  // "Pu" is a UNIT seat, not a person. isSeat=true means the row is permanent
  // ("Prof Unit") and currentHolder names the rotating person (Dr. Kasun).
  isSeat        Boolean @default(false)
  currentHolder String?

  // Pool membership window. Joiners start tallies at 0; leavers' data is KEPT.
  activeFrom  DateTime
  activeUntil DateTime? // null = currently active

  slots          DutySlot[]
  secondOnCalls  DutySlot[]           @relation("SecondOnCall")
  unavailability UnavailabilityDate[]
  createdAt      DateTime             @default(now())

  @@index([unitId, kind])
}

// SHO + RHO are ONE pool in Pead (configurable elsewhere): pool membership is
// derived as kind IN (SHO, RHO) for layer SHO. Other departments can split
// later via DutyConfig.poolKinds.

// ───────────────────────── Auth ─────────────────────────

enum Role {
  ADMIN
  CONSULTANT_EDITOR // E1 — Wasana
  SHO_EDITOR // E2 — Ruwanda
  // future: HO_EDITOR, MO_EDITOR, NURSE_EDITOR, VIEWER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String
  role         Role
  unitId       String? // editors are scoped to a unit; admin has null
  unit         Unit?      @relation(fields: [unitId], references: [id])
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
}

// ───────────────────────── Duty configuration ─────────────────────────
// Per-unit, per-layer shift definitions so other departments can differ.

enum RosterLayer {
  CONSULTANT
  SHO // covers the combined SHO+RHO pool
  // future: HO, MO, NURSE
}

model DutyConfig {
  id      String      @id @default(cuid())
  unitId  String
  unit    Unit        @relation(fields: [unitId], references: [id])
  layer   RosterLayer

  // Pead defaults, all editable from admin UI:
  // CONSULTANT: weekdayCasualtyHours = 8am→8am(+1d, 24h);
  //             weekendBlock Sat 8am → Mon 8am (48h), ONE consultant.
  // SHO: onCallStart "08:00", onCallEndNextDay "16:00" (32h);
  //      dayDutyStart "08:00", dayDutyEnd "16:00";
  //      nonCashWeekend = ONE person both days (counts as 2 on-calls);
  //      cashWeekend = split between 2 people.
  config Json

  // Which StaffKinds form the assignment pool for this layer (Pead SHO: ["SHO","RHO"])
  poolKinds String[]

  @@unique([unitId, layer])
}

// ───────────────────────── Rosters ─────────────────────────

enum RosterStatus {
  DRAFT
  PUBLISHED
}

model Roster {
  id      String       @id @default(cuid())
  unitId  String
  unit    Unit         @relation(fields: [unitId], references: [id])
  layer   RosterLayer
  month   String // "2026-06" (Asia/Colombo month)
  status  RosterStatus @default(DRAFT)
  version Int          @default(1) // bumped on every re-publish

  // SHO roster stores which consultant-roster version it was built against;
  // if consultant version > this, run revalidation and flag mismatched slots.
  builtAgainstVersion Int?

  slots       DutySlot[]
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([unitId, layer, month])
}

// One row per calendar day per roster. CONFIRMED model: exactly one person per
// day (the on-call); cash / post-cash are FLAGS on that day, not separate slots.

model DutySlot {
  id       String      @id @default(cuid())
  rosterId String
  roster   Roster      @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  date     DateTime    @db.Date // the calendar day (Asia/Colombo)

  staffId String
  staff   StaffMember @relation(fields: [staffId], references: [id])

  // Real timestamps (UTC) — shifts cross midnight & month boundaries.
  startsAt DateTime
  endsAt   DateTime

  // Flags (SHO layer): derived from the consultant roster's Pu days.
  isCash     Boolean @default(false) // Pu's consultant casualty day
  isPostCash Boolean @default(false) // day after a cash day; must be ≠ previous day's person

  // Consultant layer: weekend block membership (Sat+Sun same person, 48h).
  isWeekendBlock Boolean @default(false)

  // 2nd on-call (transfer duty to Colombo Children's). Not on the paper roster;
  // app default = someone NOT on-call this day; editor can swap. Nullable.
  secondOnCallId String?
  secondOnCall   StaffMember? @relation("SecondOnCall", fields: [secondOnCallId], references: [id])

  // Set true by revalidation when consultant re-publish breaks this slot.
  conflictFlag   Boolean @default(false)
  conflictReason String?

  @@unique([rosterId, date])
  @@index([staffId, date])
}

// ───────────────────────── Supporting tables ─────────────────────────

// Short-term leave: "Dr. Gihan away 10th–15th". Generator skips these dates;
// validator flags any existing assignment that overlaps.
model UnavailabilityDate {
  id      String      @id @default(cuid())
  staffId String
  staff   StaffMember @relation(fields: [staffId], references: [id])
  from    DateTime    @db.Date
  to      DateTime    @db.Date
  reason  String?

  @@index([staffId, from, to])
}

// Non-cash weekend rotation carries ACROSS months ("May last non cash – R").
// One row per unit+layer holding the last person who took a non-cash weekend.
model WeekendRotationState {
  id              String      @id @default(cuid())
  unitId          String
  unit            Unit        @relation(fields: [unitId], references: [id])
  layer           RosterLayer
  rotationOrder   String[] // staff ids in fixed order, e.g. [R, M, S, U]
  lastAssignedId  String? // who took the most recent non-cash weekend
  updatedAt       DateTime    @updatedAt

  @@unique([unitId, layer])
}

// Audit trail — required from day one. Every mutation writes a row.
enum AuditAction {
  CREATE
  UPDATE
  SWAP
  PUBLISH
  REPUBLISH
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String // "Roster", "DutySlot", "StaffMember", ...
  entityId  String
  before    Json? // snapshot for swaps/edits
  after     Json?
  createdAt DateTime    @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ───────────────────────── Validation rules (implemented in code, listed here) ─
// V1  Every day of the month has exactly one DutySlot per roster.
// V2  No back-to-back days for the same person (except consultant weekend block,
//     and except the SHO non-cash weekend pair).
// V3  Consultant: exactly one weekend block per consultant when month has 4
//     weekends; 5th weekend = "needs decision" flag, chosen via fairness history.
// V4  SHO: isCash days must equal the published consultant roster's Pu days.
// V5  isPostCash day's person ≠ previous day's (cash) person.
// V6  Cash weekend: Sat and Sun must be two different people; following Monday
//     isPostCash. Non-cash weekend: Sat and Sun must be the SAME person.
// V7  No assignment on a person's UnavailabilityDate.
// V8  Assignments only within staff activeFrom/activeUntil.
// V9  Generator must check the previous month's tail (last slots) for V2 and
//     post-cash continuation across the boundary.
