# Neon POOLED connection string (-pooler host) — used at runtime
DATABASE_URL=

# Neon DIRECT connection string — used by prisma migrate only
DIRECT_URL=

# 32+ random bytes (e.g. `openssl rand -base64 32`)
JWT_SECRET=

# Seed admin account (used by prisma/seed.ts, M1)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
